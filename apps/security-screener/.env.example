# The canonical public Graph Network gateway endpoints (and the matching
# gateway API key) are hardcoded in src/lib/config.ts — you do NOT need to set
# any of the variables below to run or build the screener. They exist only as
# local-dev overrides for when you want to point a specific chain at a
# different graph-node (e.g. the local docker-compose stack in
# apps/security-subgraph, or your own Studio deployment), or use a personal
# throwaway API key instead of the shared one.
#
# If you set one of these, it overrides the hardcoded value at build time. For
# IPFS pins that need to be repointable WITHOUT a rebuild, use the runtime
# `window.__BRAVA_SCREENER__.subgraphs` / `.graphApiKey` overrides instead —
# see the README.

# VITE_SUBGRAPH_ARBITRUM=http://localhost:8000/subgraphs/name/brava/security-arbitrum
# VITE_SUBGRAPH_BASE=http://localhost:8100/subgraphs/name/brava/security-base
# VITE_SUBGRAPH_MAINNET=http://localhost:8200/subgraphs/name/brava/security-mainnet

# Optional: override the baked-in Graph Network gateway API key. Leave unset
# to use the shared public key from src/lib/config.ts. Set to an empty string
# to run against anonymous endpoints (e.g. Studio / a local graph-node) that
# reject the Authorization header.
# VITE_GRAPH_API_KEY=

# Optional build metadata surfaced in the Verify-yourself section. Set by the
# release workflow; safe to leave unset locally.
#
# Note: the IPFS CID and the pinned-bundle SHA-256 are intentionally NOT baked
# in — embedding them would be self-referential. They are published in the
# matching GitHub release instead.
VITE_BUILD_COMMIT=
VITE_BUILD_TIME=
VITE_BUNDLE_HASH=
