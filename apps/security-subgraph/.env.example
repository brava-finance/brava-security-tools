# RPC URLs used by the local graph-node docker-compose stack.
# Use a paid archive provider (Alchemy, Infura, QuickNode) for reliable
# historical access. Public RPCs will frequently rate-limit indexing.
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/REPLACE_ME
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/REPLACE_ME

# Optional: skip historical indexing by starting from a recent block.
# Pick something a few thousand blocks behind the current head for fast
# local iteration; set empty / unset to use the production startBlock.
# START_BLOCK_ARBITRUM=399000000
# START_BLOCK_BASE=39000000
