# The canonical public Graph Studio endpoints are hardcoded in
# src/lib/config.ts — you do NOT need to set any of the variables below to run
# or build the screener. They exist only as local-dev overrides for when you
# want to point a specific chain at a different graph-node (e.g. the local
# docker-compose stack in apps/security-subgraph, or your own Studio deployment).
#
# If you set one of these, it overrides the hardcoded URL for that chain at
# build time. For IPFS pins that need to be repointable WITHOUT a rebuild, use
# the runtime `window.__BRAVA_SCREENER__.subgraphs` override instead — see the
# README.

# VITE_SUBGRAPH_ARBITRUM=http://localhost:8000/subgraphs/name/brava/security-arbitrum
# VITE_SUBGRAPH_BASE=http://localhost:8100/subgraphs/name/brava/security-base
# VITE_SUBGRAPH_MAINNET=http://localhost:8200/subgraphs/name/brava/security-mainnet

# Optional build metadata surfaced in the Verify-yourself section. Set by the
# release workflow; safe to leave unset locally.
#
# Note: the IPFS CID and the pinned-bundle SHA-256 are intentionally NOT baked
# in — embedding them would be self-referential. They are published in the
# matching GitHub release instead.
VITE_BUILD_COMMIT=
VITE_BUILD_TIME=
VITE_BUNDLE_HASH=
