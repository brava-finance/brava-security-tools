VITE_SUBGRAPH_ARBITRUM=https://api.studio.thegraph.com/query/YOUR_ID/brava-security-arbitrum/version/latest
VITE_SUBGRAPH_BASE=https://api.studio.thegraph.com/query/YOUR_ID/brava-security-base/version/latest
VITE_SUBGRAPH_MAINNET=https://api.studio.thegraph.com/query/YOUR_ID/brava-security-ethereum/version/latest

# When testing against the local docker-compose stack in apps/security-subgraph,
# each chain runs on its own graph-node instance (different ports):
# VITE_SUBGRAPH_ARBITRUM=http://localhost:8000/subgraphs/name/brava/security-arbitrum
# VITE_SUBGRAPH_BASE=http://localhost:8100/subgraphs/name/brava/security-base

# Optional build metadata surfaced in the Verify-yourself section.
# Set by the release script; safe to leave unset locally.
VITE_BUILD_COMMIT=
VITE_BUILD_TIME=
VITE_BUNDLE_HASH=
VITE_IPFS_CID=
